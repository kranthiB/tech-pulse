        <mxCell id="wt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#856404;" value="Most Teams Get This Wrong" vertex="1">
          <mxGeometry height="18" width="500" x="44" y="576" as="geometry" />
        </mxCell>
        <mxCell id="wb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;whiteSpace=wrap;" value="Teams use a single category for all synthetic data needs. Red-team data is used for training (wrong). Evaluation-only data has training distribution overlap (wrong). Augmented data is treated as fully synthetic in privacy assessments (wrong). Each category has distinct generation requirements, validation requirements, and appropriate applications." vertex="1">
