        <mxCell id="r1c1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=12;fontStyle=1;fontColor=#1B3A6B;align=left;verticalAlign=top;" value="1. Augmented Real Data" vertex="1">
          <mxGeometry height="110" width="196" x="28" y="116" as="geometry" />
        </mxCell>
        <mxCell id="r1c2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#CBD8EF;fontSize=11;fontColor=#2E7D32;align=left;verticalAlign=top;" value="Volume expansion where representative seed data exists. Minority class oversampling. Linguistic variation for NLP systems." vertex="1">
          <mxGeometry height="110" width="456" x="224" y="116" as="geometry" />
        </mxCell>
        <mxCell id="r1c3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#CBD8EF;fontSize=11;fontColor=#7A6000;align=left;verticalAlign=top;" value="Amplifies existing distribution gaps. If the seed data underrepresents a class, augmentation expands the underrepresentation rather than correcting it." vertex="1">
          <mxGeometry height="110" width="459" x="680" y="116" as="geometry" />
        </mxCell>
        <mxCell id="r2c1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=12;fontStyle=1;fontColor=#1B3A6B;align=left;verticalAlign=top;" value="2. Fully Synthetic Data" vertex="1">
          <mxGeometry height="110" width="196" x="28" y="226" as="geometry" />
        </mxCell>
        <mxCell id="r2c2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#CBD8EF;fontSize=11;fontColor=#2E7D32;align=left;verticalAlign=top;" value="Pre-training, tail scenario coverage, privacy-safe development in regulated industries. No lineage to real records." vertex="1">
          <mxGeometry height="110" width="456" x="224" y="226" as="geometry" />
        </mxCell>
        <mxCell id="r2c3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#CBD8EF;fontSize=11;fontColor=#7A6000;align=left;verticalAlign=top;" value="Distribution coverage is not guaranteed. Requires distribution matching validation against real holdout. Never use as the sole evaluation source without downstream task correlation check." vertex="1">
          <mxGeometry height="110" width="459" x="680" y="226" as="geometry" />
        </mxCell>
        <mxCell id="r3c1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;fontSize=12;fontStyle=1;fontColor=#856404;align=left;verticalAlign=top;" value="3. Adversarial and Red-Team Synthetic Data" vertex="1">
          <mxGeometry height="110" width="196" x="28" y="336" as="geometry" />
        </mxCell>
        <mxCell id="r3c2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#CBD8EF;fontSize=11;fontColor=#2E7D32;align=left;verticalAlign=top;" value="Pre-deployment safety testing. Jailbreak and prompt injection probing. Decision boundary stress-testing. Required for every production AI system." vertex="1">
          <mxGeometry height="110" width="456" x="224" y="336" as="geometry" />
        </mxCell>
        <mxCell id="r3c3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#CBD8EF;fontSize=11;fontColor=#7A6000;align=left;verticalAlign=top;" value="Treated as one-time pre-launch activity instead of continuous practice. Red-team datasets must be refreshed on every model update — not anchored to the original version." vertex="1">
          <mxGeometry height="110" width="459" x="680" y="336" as="geometry" />
        </mxCell>
        <mxCell id="r4c1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=12;fontStyle=1;fontColor=#1B3A6B;align=left;verticalAlign=top;" value="4. Evaluation-Only Synthetic Data" vertex="1">
          <mxGeometry height="110" width="196" x="28" y="446" as="geometry" />
        </mxCell>
        <mxCell id="r4c2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#CBD8EF;fontSize=11;fontColor=#2E7D32;align=left;verticalAlign=top;" value="LLM golden dataset construction. Q-A pairs with definitional ground truth. Multi-turn dialogue evaluation sets. Eliminates human labeling cost and inter-annotator disagreement." vertex="1">
          <mxGeometry height="110" width="456" x="224" y="446" as="geometry" />
        </mxCell>
        <mxCell id="r4c3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#CBD8EF;fontSize=11;fontColor=#7A6000;align=left;verticalAlign=top;" value="Must be generated independently from the training pipeline. Any distribution overlap between evaluation-only synthetic data and training data produces optimistic metrics that do not hold in production." vertex="1">
          <mxGeometry height="110" width="459" x="680" y="446" as="geometry" />
        </mxCell>
