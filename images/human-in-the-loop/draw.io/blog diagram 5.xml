        <mxCell id="d1hdrt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#FFFFFF;" value="Financial Decisions" vertex="1">
          <mxGeometry height="32" width="535" x="28" y="136" as="geometry" />
        </mxCell>
        <mxCell id="d1crit" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2D5AA0;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;" value="Consequence: HIGH     Auditability: HIGH (regulatory)" vertex="1">
          <mxGeometry height="24" width="535" x="28" y="168" as="geometry" />
        </mxCell>
        <mxCell id="d1bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
          <mxGeometry height="198" width="535" x="28" y="192" as="geometry" />
        </mxCell>
        <mxCell id="d1b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" value="Automated decisions above monetary thresholds carry regulatory obligations in most jurisdictions.  Design challenge: Build a review interface that captures a legally defensible decision record without creating a throughput bottleneck.  Specific considerations: - Customer balance decisions: full context package required - Credit determinations: auditability criterion alone triggers Level 1 - Large transaction approvals: structured decision record mandatory  Audit retention: Typically 7 years in financial services" vertex="1">
          <mxGeometry height="198" width="535" x="28" y="192" as="geometry" />
        </mxCell>
        <mxCell id="d2hdr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="32" width="535" x="604" y="136" as="geometry" />
        </mxCell>
        <mxCell id="d2hdrt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#FFFFFF;" value="Healthcare Recommendations" vertex="1">
          <mxGeometry height="32" width="535" x="604" y="136" as="geometry" />
        </mxCell>
        <mxCell id="d2crit" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2D5AA0;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;" value="Consequence: HIGH     Auditability: HIGH (clinical documentation standards)" vertex="1">
          <mxGeometry height="24" width="535" x="604" y="168" as="geometry" />
        </mxCell>
        <mxCell id="d2bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
          <mxGeometry height="198" width="535" x="604" y="192" as="geometry" />
        </mxCell>
        <mxCell id="d2b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" value="Clinical decision support agents operate in a high-cognitive-load environment where the human reviewer is a clinician with limited review time.  Design challenge: Compress context without losing clinical relevance. Integrate escalation into existing clinical workflows, not a parallel notification channel.  Specific considerations: - Context packages must meet clinical documentation standards - Review interface must integrate with EHR workflow - Audit record must meet jurisdiction-specific requirements  Key difference from other domains: Reviewer expertise level is itself a design variable" vertex="1">
          <mxGeometry height="198" width="535" x="604" y="192" as="geometry" />
        </mxCell>
        <mxCell id="d3hdr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="32" width="535" x="28" y="404" as="geometry" />
        </mxCell>
        <mxCell id="d3hdrt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#FFFFFF;" value="Legal Document Generation" vertex="1">
          <mxGeometry height="32" width="535" x="28" y="404" as="geometry" />
        </mxCell>
        <mxCell id="d3crit" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2D5AA0;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;" value="Consequence: HIGH (errors outlast the workflow)     Auditability: HIGH" vertex="1">
          <mxGeometry height="24" width="535" x="28" y="436" as="geometry" />
        </mxCell>
        <mxCell id="d3bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
          <mxGeometry height="176" width="535" x="28" y="460" as="geometry" />
        </mxCell>
        <mxCell id="d3b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" value="Contracts, compliance filings, and regulatory submissions carry legal consequences that outlast the workflow that generated them.  Design challenge: Ensure the reviewer has sufficient domain expertise to catch agent errors, not just sufficient time to approve the output.  Specific considerations: - Reviewer qualification must be tracked as part of the audit record - Version control of reviewed documents is an engineering requirement - Audit record must capture what version the human approved" vertex="1">
          <mxGeometry height="176" width="535" x="28" y="460" as="geometry" />
        </mxCell>
        <mxCell id="d4hdr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="32" width="535" x="604" y="404" as="geometry" />
        </mxCell>
        <mxCell id="d4hdrt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#FFFFFF;" value="Hiring and Performance Decisions" vertex="1">
          <mxGeometry height="32" width="535" x="604" y="404" as="geometry" />
        </mxCell>
        <mxCell id="d4crit" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2D5AA0;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;" value="Consequence: HIGH (fairness/discrimination risk)     Human Value: CRITICAL beyond accuracy" vertex="1">
          <mxGeometry height="24" width="535" x="604" y="436" as="geometry" />
        </mxCell>
        <mxCell id="d4bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
          <mxGeometry height="176" width="535" x="604" y="460" as="geometry" />
        </mxCell>
        <mxCell id="d4b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" value="Agentic systems in talent decisions carry fairness and discrimination risk that a purely accuracy-based checkpoint framework can miss.  Design challenge: The human&#39;s role is not just to catch agent errors but to ensure the decision meets standards that go beyond the agent&#39;s optimization objective.  Specific considerations: - Checkpoint must include explicit diversity and bias review components - Not just output approval — process validation is required - Human Value criterion includes fairness dimensions not in accuracy metrics" vertex="1">
          <mxGeometry height="176" width="535" x="604" y="460" as="geometry" />
        </mxCell>
        <mxCell id="pbg" parent="1" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#81C784;" value="" vertex="1">
