        <mxCell id="htitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#FFFFFF;" value="Human-in-the-Loop Design for Agentic Systems" vertex="1">
          <mxGeometry height="62" width="820" x="28" y="10" as="geometry" />
        </mxCell>
        <mxCell id="fhdr" parent="1" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;" value="" vertex="1">
