        <mxCell id="p6t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#AACCFF;" value="The Right Design Principle" vertex="1">
          <mxGeometry height="18" width="356" x="822" y="294" as="geometry" />
        </mxCell>
