          <mxGeometry height="4" width="368" x="816" y="316" as="geometry" />
        </mxCell>
        <mxCell id="p6b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#EAF1FB;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Instrument checkpoints from day one — not after the first incident.  Measure: decision time distribution, override rate trend, agent error rate at checkpoints, false safety indicator.  Human-in-the-Loop is an architecture decision. Design it deliberately." vertex="1">
