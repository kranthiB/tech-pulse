        <mxCell id="p5t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#856404;" value="Most Teams Get This Wrong" vertex="1">
          <mxGeometry height="18" width="364" x="418" y="294" as="geometry" />
        </mxCell>
        <mxCell id="p5s" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#5A6A80;" value="Adding checkpoints to feel safe, not to be safe" vertex="1">
          <mxGeometry height="14" width="364" x="418" y="312" as="geometry" />
        </mxCell>
        <mxCell id="p5div" parent="1" style="line;strokeColor=#FFCA2C;fillColor=none;strokeWidth=1;" value="" vertex="1">
          <mxGeometry height="4" width="376" x="412" y="330" as="geometry" />
        </mxCell>
        <mxCell id="p5b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Teams add a human approval step in the final week before launch — without designing context packages, escalation paths, effectiveness metrics, or instrumentation. &#xa;&#xa;A checkpoint where humans approve 98% of decisions in under 2 seconds is liability theater. &#xa;&#xa;Effective oversight requires: genuine decision authority + sufficient context + volume low enough for real deliberation." vertex="1">
          <mxGeometry height="134" width="370" x="418" y="338" as="geometry" />
        </mxCell>
        <mxCell id="p6bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="196" width="384" x="808" y="286" as="geometry" />
