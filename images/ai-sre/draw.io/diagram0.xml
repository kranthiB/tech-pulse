        <mxCell id="p3t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#856404;" value="The Identity Split" vertex="1">
          <mxGeometry height="18" width="356" x="822" y="82" as="geometry" />
        </mxCell>
        <mxCell id="p3s" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#5A6A80;" value="Investigative and remediation credentials must never be the same one" vertex="1">
          <mxGeometry height="14" width="356" x="822" y="100" as="geometry" />
        </mxCell>
        <mxCell id="p3div" parent="1" style="line;strokeColor=#FFCA2C;fillColor=none;strokeWidth=1;" value="" vertex="1">
          <mxGeometry height="4" width="368" x="816" y="118" as="geometry" />
        </mxCell>
        <mxCell id="p3b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Investigative identity: broad, read-only, reaches wherever the signal might be. &#xa;&#xa;Remediation identity: narrow, scoped by system and by action type. &#xa;&#xa;Both dimensions matter. &#xa;&#xa;The moment an agent has enough access to investigate well, it has enough access to cause damage. A system prompt is not an access control." vertex="1">
          <mxGeometry height="134" width="362" x="822" y="126" as="geometry" />
        </mxCell>
        <mxCell id="p4bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD8EF;" value="" vertex="1">
