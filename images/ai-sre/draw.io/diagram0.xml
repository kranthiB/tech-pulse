        <mxCell id="p5s" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#5A6A80;" value="Turning on autonomous remediation because the demo looked good" vertex="1">
          <mxGeometry height="14" width="364" x="418" y="306" as="geometry" />
        </mxCell>
        <mxCell id="p5div" parent="1" style="line;strokeColor=#FFCA2C;fillColor=none;strokeWidth=1;" value="" vertex="1">
          <mxGeometry height="4" width="376" x="412" y="324" as="geometry" />
