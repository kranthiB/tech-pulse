        </mxCell>
        <mxCell id="p2t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#1B3A6B;" value="Six-Step Workflow" vertex="1">
          <mxGeometry height="18" width="364" x="418" y="82" as="geometry" />
        </mxCell>
        <mxCell id="p2s" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#5A6A80;" value="Step four is the governance boundary; step six is where it compounds" vertex="1">
          <mxGeometry height="14" width="364" x="418" y="100" as="geometry" />
        </mxCell>
        <mxCell id="p2div" parent="1" style="line;strokeColor=#E0E8F4;fillColor=none;strokeWidth=1;" value="" vertex="1">
          <mxGeometry height="4" width="376" x="412" y="118" as="geometry" />
        </mxCell>
        <mxCell id="p2b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Detect and diagnose. Surface context. Provide analysis. Suggest remediation. Execute approved. Learn. &#xa;&#xa;Step four is the explicit governance choice: human approval required, or not. &#xa;&#xa;Step six is the learning loop that makes the system measurably better at your specific environment over time, not a benchmark environment." vertex="1">
          <mxGeometry height="134" width="370" x="418" y="126" as="geometry" />
        </mxCell>
