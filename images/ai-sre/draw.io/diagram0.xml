        </mxCell>
        <mxCell id="p4t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#1B3A6B;" value="Progressive Autonomy" vertex="1">
          <mxGeometry height="18" width="356" x="22" y="288" as="geometry" />
        </mxCell>
        <mxCell id="p4s" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#5A6A80;" value="Earn it per failure class, never grant it globally" vertex="1">
          <mxGeometry height="14" width="356" x="22" y="306" as="geometry" />
        </mxCell>
        <mxCell id="p4div" parent="1" style="line;strokeColor=#E0E8F4;fillColor=none;strokeWidth=1;" value="" vertex="1">
          <mxGeometry height="4" width="368" x="16" y="324" as="geometry" />
        </mxCell>
        <mxCell id="p4b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Stage 1: Read-only. Safe from day one. &#xa;&#xa;Stage 2: Approval-gated. Tests diagnostic trust under real conditions. &#xa;&#xa;Stage 3: Autonomous. Earned per failure class with three criteria met: well-defined signature, deterministic fix, contained blast radius. &#xa;&#xa;&#xa;Stage 3 authority is a portfolio of narrow grants, not a single switch." vertex="1">
          <mxGeometry height="134" width="362" x="22" y="332" as="geometry" />
        </mxCell>
