        <mxCell id="p6s" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#5A6A80;" value="Upside in minutes. Downside in connected systems." vertex="1">
          <mxGeometry height="14" width="356" x="822" y="306" as="geometry" />
