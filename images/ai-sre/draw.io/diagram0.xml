        <mxCell id="p5b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Diagnostic quality and remediation safety are different properties. One good demo does not prove both. &#xa;&#xa;A broad service account is not a substitute for a minimum-privilege identity split. &#xa;&#xa;Benchmarking purely on speed is not a substitute for tracking diagnostic accuracy. Skipping these is how teams produce an agent-caused incident in month one." vertex="1">
          <mxGeometry height="134" width="370" x="418" y="332" as="geometry" />
