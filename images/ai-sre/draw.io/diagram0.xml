        <mxCell id="p1b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="AIOps: the core artifact is a ranked alert queue. A human investigates, decides, and acts. &#xa;&#xa;AI SRE: the core artifact is a tested, evidence-backed root-cause hypothesis paired with an executed remediation.  Marketing language no longer distinguishes them. Only the artifact does." vertex="1">
          <mxGeometry height="134" width="362" x="22" y="126" as="geometry" />
        </mxCell>
        <mxCell id="p2bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD8EF;" value="" vertex="1">
