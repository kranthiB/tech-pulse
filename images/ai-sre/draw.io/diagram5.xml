        <mxCell id="r2b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;whiteSpace=wrap;" value="A fix correct in isolation can degrade a dependent service invisibly, and the agent has already moved on by the time the degradation surfaces. A wrong fix propagates across connected systems as fast as a right one would, because speed is not conditional on correctness." vertex="1">
