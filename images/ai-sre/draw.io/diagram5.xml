        <mxCell id="r1b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;whiteSpace=wrap;" value="Does not perform this informal validation unless deliberately engineered to check for exactly these signals. The agent executes based on what it can see, not what a human would remember to check." vertex="1">
