        <mxCell id="l1b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;whiteSpace=wrap;" value="Naturally validates a fix against context not visible in telemetry: a remembered deployment, an adjacent incident running in parallel, a reason not to restart that particular service right now. This validation is informal and inconsistent, but it is exactly what stops a technically plausible fix from causing a worse problem." vertex="1">
          <mxGeometry height="86" width="508" x="44" y="134" as="geometry" />
