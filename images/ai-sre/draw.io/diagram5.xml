        <mxCell id="l2b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#2E7D32;whiteSpace=wrap;" value="What it catches: low-probability, high-severity interactions between the proposed fix and the current system state. Informal, slow, but genuinely protective." vertex="1">
          <mxGeometry height="58" width="508" x="44" y="242" as="geometry" />
        </mxCell>
