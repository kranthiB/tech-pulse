        <mxCell id="asyb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#EAF1FB;whiteSpace=wrap;" value="Upside is measured in minutes saved per incident. Downside is measured in how many downstream systems the blast radius reaches before the wrong fix is caught and reversed." vertex="1">
