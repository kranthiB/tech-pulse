        </mxCell>
        <mxCell id="colb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#EAF1FB;whiteSpace=wrap;" value="The moment an agent has enough access to investigate well, it has enough access to cause damage beyond the incident&#39;s scope. These must never be the same credential." vertex="1">
