        </mxCell>
        <mxCell id="l2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=11;align=left;verticalAlign=middle;" value="Read broadly. The investigative identity needs to reach wherever the signal might be, because the agent does not know the answer before it looks." vertex="1">
          <mxGeometry height="72" width="450" x="118" y="208" as="geometry" />
        </mxCell>
        <mxCell id="r1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;fontColor=#7A6000;fontSize=11;align=left;verticalAlign=middle;" value="Narrow, high-risk access scoped to the smallest blast radius required for the job: by system, by action type, and by time window." vertex="1">
          <mxGeometry height="72" width="531" x="608" y="128" as="geometry" />
        </mxCell>
        <mxCell id="r2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;fontColor=#7A6000;fontSize=11;align=left;verticalAlign=middle;" value="Act narrowly. Both dimensions matter: which systems can be touched and what action types are permitted within them. A remediation identity narrow by system but broad by action type still concentrates too much capability." vertex="1">
