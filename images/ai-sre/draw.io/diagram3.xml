        <mxCell id="matb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;whiteSpace=wrap;" value="A remediation identity narrow by system but broad by action (able to restart, reconfigure, and modify schemas within one service) still concentrates too much capability. Grant cells in the matrix individually: each system-action combination considered separately, not as a row or column." vertex="1">
          <mxGeometry height="48" width="1083" x="44" y="384" as="geometry" />
