        <mxCell id="colt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#AACCFF;" value="Collapsing These Into One Credential" vertex="1">
