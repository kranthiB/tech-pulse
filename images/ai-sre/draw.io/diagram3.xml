        <mxCell id="wt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#856404;" value="Most Teams Get This Wrong" vertex="1">
          <mxGeometry height="18" width="400" x="44" y="456" as="geometry" />
        </mxCell>
        <mxCell id="wb" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Issuing one broad service account and trusting the agent&#39;s own reasoning to behave conservatively within it. A system prompt is not an access control.  The difference is architectural: a service account can be compromised, misconfigured, or prompt-injected, and when it is, the scope of that credential is the blast radius. Minimum-privilege identity design is the only reliable containment layer." vertex="1">
