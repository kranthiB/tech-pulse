        <mxCell id="l1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=11;align=left;verticalAlign=middle;" value="Broad, low-risk access across telemetry, logs, traces, and configuration state. Breadth is what makes diagnosis genuinely useful." vertex="1">
