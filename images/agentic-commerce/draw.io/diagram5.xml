        <mxCell id="wb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;whiteSpace=wrap;" value="Treating these three as legal review items to check off once at launch, rather than engineering work that has to evolve every time a new protocol or payment network is added. Each new integration point changes the attribution chain and may change the liability allocation that was previously agreed on." vertex="1">
