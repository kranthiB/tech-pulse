        <mxCell id="pb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#1B5E20;whiteSpace=wrap;" value="The most valuable work in agentic commerce right now is not the checkout button. It is the plumbing underneath it, and the plumbing does not care whether the button gets used." vertex="1">
