        <mxCell id="wt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#856404;" value="Most Teams Get This Wrong" vertex="1">
          <mxGeometry height="18" width="400" x="44" y="404" as="geometry" />
        </mxCell>
        <mxCell id="wb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;whiteSpace=wrap;" value="Benchmarking success against did this displace traditional checkout. The more useful baseline is did this reduce integration friction for transactions that were already going to happen through some channel. Judged against that baseline, the protocol and authentication layer has already delivered real value, even while the consumer product built on top of it did not." vertex="1">
          <mxGeometry height="46" width="1083" x="44" y="424" as="geometry" />
