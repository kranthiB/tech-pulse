        </mxCell>
        <mxCell id="c1bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
          <mxGeometry height="138" width="540" x="28" y="128" as="geometry" />
        </mxCell>
        <mxCell id="c1b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;whiteSpace=wrap;" value="Expose structured product and pricing data through commerce-description protocols. Treat it as a low-cost hedge, not a bet on conversational checkout demand.  Concretely: expose a standards-compliant integration surface through whichever protocol your largest customer segment is most likely to encounter. Measure actual agent-driven traffic against actual agent-driven conversion before investing further.  Do not build a bespoke conversational checkout experience before the data justifies it." vertex="1">
          <mxGeometry height="124" width="508" x="44" y="134" as="geometry" />
        </mxCell>
        <mxCell id="c2hdr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B5E20;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="36" width="531" x="608" y="84" as="geometry" />
        </mxCell>
        <mxCell id="c2hdrt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#FFFFFF;" value="If You Are B2B or Machine-to-Machine" vertex="1">
          <mxGeometry height="36" width="531" x="608" y="84" as="geometry" />
        </mxCell>
        <mxCell id="c2bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#81C784;" value="" vertex="1">
          <mxGeometry height="138" width="531" x="608" y="128" as="geometry" />
        </mxCell>
        <mxCell id="c2b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#2E7D32;whiteSpace=wrap;" value="Treat payment authorization as first-class agent architecture from the outset. Adopt the machine-payment protocol layer. This adoption curve is accelerating independent of consumer sentiment.  Concretely: scoped payment credentials with hard spend ceilings enforced at the credential level itself, not as a system-prompt instruction the agent&#39;s own reasoning is trusted to honor.  This segment is where the actual engineering substance is being rewarded right now." vertex="1">
          <mxGeometry height="124" width="499" x="624" y="134" as="geometry" />
        </mxCell>
        <mxCell id="uhdr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#856404;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="36" width="1111" x="28" y="278" as="geometry" />
        </mxCell>
        <mxCell id="uhdrt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#FFFFFF;" value="Regardless of Which Side You Sit On" vertex="1">
          <mxGeometry height="36" width="900" x="44" y="278" as="geometry" />
        </mxCell>
        <mxCell id="ubg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;" value="" vertex="1">
          <mxGeometry height="64" width="1111" x="28" y="322" as="geometry" />
        </mxCell>
        <mxCell id="ub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;whiteSpace=wrap;" value="Spend control, attribution, and liability allocation are not optional homework. They need dedicated ownership and contractual clarity before the first real transaction, not retrofitted after the first dispute.  A useful forcing function: require a one-page document naming who owns each question, what the current answer is, and when it was last reviewed, as a condition of launch." vertex="1">
          <mxGeometry height="56" width="1083" x="44" y="326" as="geometry" />
        </mxCell>
        <mxCell id="wbg" parent="1" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;" value="" vertex="1">
