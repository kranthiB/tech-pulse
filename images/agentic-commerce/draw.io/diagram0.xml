        <mxCell id="p2b" parent="1" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;spacingLeft=4;spacingTop=4;whiteSpace=wrap;" value="Consumer adoption: product-market fit question. &#xa;Current answer: not yet. &#xa;&#xa;Infrastructure maturity: engineering capability question. &#xa;Current answer: already happening, accelerating. &#xa;&#xa;Teams that conflate these two as one question called agentic commerce make worse resourcing decisions than teams that separate them." vertex="1">
