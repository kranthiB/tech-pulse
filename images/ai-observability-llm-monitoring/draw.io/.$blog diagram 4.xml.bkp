        <mxCell id="d3b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#2E7D32;whiteSpace=wrap;" value="Re-run anchor pair evaluation against the prior baseline state (prior prompt version, prior model, prior index snapshot) to confirm which change caused the regression. Roll back, fix forward, or accept with monitoring intensified." vertex="1">
