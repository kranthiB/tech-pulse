        <mxCell id="d2b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#2E7D32;whiteSpace=wrap;" value="Check prompt lineage for changes in the drift window. Was a prompt template modified? Was a model version updated? Was the knowledge base refreshed? The causal change is almost always one of these three." vertex="1">
          <mxGeometry height="78" width="328" x="414" y="626" as="geometry" />
