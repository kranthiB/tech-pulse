        <mxCell id="d2t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#1B5E20;" value="Step 2" vertex="1">
          <mxGeometry height="16" width="324" x="414" y="608" as="geometry" />
