        <mxCell id="d1t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#1B5E20;" value="Step 1" vertex="1">
          <mxGeometry height="16" width="324" x="44" y="608" as="geometry" />
        </mxCell>
        <mxCell id="d1b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#2E7D32;whiteSpace=wrap;" value="Check which signal fired (A, B, C). If only A fires: system-internal change. If only B: query distribution shift. If A + B: significant regression. If C fires: user-facing impact confirmed." vertex="1">
          <mxGeometry height="78" width="328" x="44" y="626" as="geometry" />
        </mxCell>
