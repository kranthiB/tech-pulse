        <mxCell id="fq1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#AACCFF;" value="Semantic drift is the most dangerous AI production failure mode — invisible to traditional monitoring." vertex="1">
          <mxGeometry height="28" width="700" x="30" y="514" as="geometry" />
        </mxCell>
        <mxCell id="fq2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#7A9ACC;" value="You cannot monitor semantic correctness with infrastructure tools." vertex="1">
          <mxGeometry height="26" width="700" x="30" y="542" as="geometry" />
