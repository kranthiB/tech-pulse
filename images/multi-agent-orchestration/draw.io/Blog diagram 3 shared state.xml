    <mxCell id="df1" value="Q1: How many agents need to write?&#xa;&#xa;One agent only → Owned state&#xa;Multiple agents, defined authority → Shared state&#xa;Transferred once → Passed state" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;strokeWidth=1;fontSize=11;align=left;verticalAlign=top;fontColor=#1B5E20;" vertex="1" parent="1">
