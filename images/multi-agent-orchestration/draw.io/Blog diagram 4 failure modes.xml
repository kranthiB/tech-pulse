    <mxCell id="cmtitle" value="The Common Mitigation Principle" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#1B3A6B;" vertex="1" parent="1">
      <mxGeometry x="48" y="592" width="400" height="32" as="geometry" />
