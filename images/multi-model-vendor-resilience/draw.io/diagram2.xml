        </mxCell>
        <mxCell id="l2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=11;align=left;verticalAlign=middle;" value="Commercial: bankruptcy, acquisition, pricing changes. Rarely geopolitical. Timeline is slow-moving and often negotiable." vertex="1">
          <mxGeometry height="76" width="452" x="108" y="212" as="geometry" />
        </mxCell>
        <mxCell id="l3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=11;align=left;verticalAlign=middle;" value="Peripheral: a failing payment processor breaks checkout, not the product&#39;s core reasoning. Graceful degradation paths almost always exist." vertex="1">
