        <mxCell id="l1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;fontSize=11;align=left;verticalAlign=middle;" value="Switching cost problem: destination behavior is knowable and testable in advance against a documented specification. The risk is friction, not surprise." vertex="1">
