        <mxCell id="r3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;fontColor=#7A6000;fontSize=11;align=left;verticalAlign=middle;" value="Embedded: the model often is the reasoning layer, with no graceful degradation path ever built because the assumption was that it would simply always be there." vertex="1">
