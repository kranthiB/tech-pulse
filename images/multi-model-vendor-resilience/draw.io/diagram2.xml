        <mxCell id="r2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;fontColor=#7A6000;fontSize=11;align=left;verticalAlign=middle;" value="Geopolitical: export controls and national-security determinations can suspend service independent of contract or quality. The vendor may be willing and legally prohibited." vertex="1">
