        </mxCell>
        <mxCell id="r1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;fontColor=#7A6000;fontSize=11;align=left;verticalAlign=middle;" value="Behavior is not fully specified: a probabilistic system whose output on your data was never formally documented by the vendor. Switching requires re-validation, not just remapping." vertex="1">
