        <mxCell id="s1h" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=center;" value="Stage 1: Single-Vendor Dependency" vertex="1">
