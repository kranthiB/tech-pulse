        </mxCell>
        <mxCell id="hbar" parent="1" style="rounded=0;fillColor=#1B3A6B;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="4" width="1111" x="28" y="294" as="geometry" />
        </mxCell>
        <mxCell id="ht" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#1B3A6B;" value="Honest Self-Assessment" vertex="1">
          <mxGeometry height="14" width="300" x="44" y="300" as="geometry" />
        </mxCell>
        <mxCell id="hb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;whiteSpace=wrap;" value="Most organizations sit at Stage 1 or Stage 2 today. Stage 3 is achievable within a single quarter for a team that prioritizes it. Stage 4 is a sustained operational commitment, not a project. A useful heuristic: ask what would happen to the business if this specific system&#39;s primary model vendor vanished for three weeks with no warning. Where the honest answer is &#39;a serious problem,&#39; that system belongs on the path toward Stage 4." vertex="1">
          <mxGeometry height="56" width="1083" x="44" y="316" as="geometry" />
        </mxCell>
        <mxCell id="wbg" parent="1" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFFDF0;strokeColor=#FFCA2C;" value="" vertex="1">
          <mxGeometry height="80" width="1111" x="28" y="392" as="geometry" />
        </mxCell>
        <mxCell id="wbar" parent="1" style="rounded=0;fillColor=#856404;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="5" width="1111" x="28" y="392" as="geometry" />
        </mxCell>
        <mxCell id="wt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#856404;" value="Most Teams Get This Wrong" vertex="1">
          <mxGeometry height="18" width="400" x="44" y="398" as="geometry" />
        </mxCell>
        <mxCell id="wb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#7A6000;whiteSpace=wrap;" value="Treating this as a one-time procurement decision. A fallback qualified against last year&#39;s evaluation suite, against a system whose prompts, retrieval sources, and task distribution have since changed, is a stale assumption with a qualification date attached, not a validated fallback. Vendor resilience needs the same operational discipline as any other production dependency: periodic re-qualification, scheduled failover drills, and clear ownership." vertex="1">
          <mxGeometry height="46" width="1083" x="44" y="418" as="geometry" />
        </mxCell>
        <mxCell id="dfbg" parent="1" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#81C784;" value="" vertex="1">
          <mxGeometry height="80" width="1111" x="28" y="484" as="geometry" />
        </mxCell>
        <mxCell id="dfbar" parent="1" style="rounded=0;fillColor=#1B5E20;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="4" width="1111" x="28" y="484" as="geometry" />
        </mxCell>
        <mxCell id="dft" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#1B5E20;" value="Decision Framework" vertex="1">
          <mxGeometry height="16" width="400" x="44" y="490" as="geometry" />
        </mxCell>
        <mxCell id="dfb" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#2E7D32;whiteSpace=wrap;" value="Locate your organization on this spectrum honestly, then invest one stage at a time. Moving through these stages is not free, and should not be pursued uniformly across every system in a portfolio. Where the honest answer to &#39;what happens if this vendor vanished for three weeks&#39; is &#39;a serious problem,&#39; that system belongs on the path toward Stage 4. Where the honest answer is &#39;an inconvenience,&#39; Stage 2 is often a defensible stopping point." vertex="1">
          <mxGeometry height="50" width="1083" x="44" y="508" as="geometry" />
        </mxCell>
