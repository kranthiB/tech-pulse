        <mxCell id="s1b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;whiteSpace=wrap;" value="All production LLM calls go to a single provider through a direct SDK integration or a gateway configured with only one upstream. No fallback exists at any layer. Describes the majority of production AI systems today." vertex="1">
          <mxGeometry height="126" width="231" x="44" y="146" as="geometry" />
        </mxCell>
