        <mxCell id="s2h" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=center;" value="Stage 2: Routed but Unqualified" vertex="1">
          <mxGeometry height="48" width="263" x="316" y="84" as="geometry" />
        </mxCell>
        <mxCell id="s2bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
          <mxGeometry height="140" width="263" x="316" y="140" as="geometry" />
        </mxCell>
        <mxCell id="s2b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;whiteSpace=wrap;" value="A secondary provider exists in configuration but has never been qualified against production evaluation data. Resilience theater: the architecture diagram shows a fallback, but nobody can say with confidence what happens to output quality if that fallback is invoked." vertex="1">
          <mxGeometry height="126" width="231" x="332" y="146" as="geometry" />
        </mxCell>
        <mxCell id="arr2" edge="1" parent="1" source="s2h" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1B3A6B;strokeWidth=2;endArrow=block;endFill=1;" target="s3h" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3h" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B3A6B;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=center;" value="Stage 3: Qualified, Cold Standby" vertex="1">
          <mxGeometry height="48" width="263" x="604" y="84" as="geometry" />
        </mxCell>
        <mxCell id="s3bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
          <mxGeometry height="140" width="263" x="604" y="140" as="geometry" />
        </mxCell>
        <mxCell id="s3b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333D4D;whiteSpace=wrap;" value="Secondary evaluated against production task categories with a known quality delta. Contractual terms for data portability and deprecation notice reviewed. Gap: the fallback has never been exercised under real traffic. Operational mechanics of failover remain unproven." vertex="1">
          <mxGeometry height="126" width="231" x="620" y="146" as="geometry" />
        </mxCell>
        <mxCell id="arr3" edge="1" parent="1" source="s3h" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1B5E20;strokeWidth=2;endArrow=block;endFill=1;" target="s4h" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s4h" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1B5E20;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=center;" value="Stage 4: Warm, Drilled, Contractually Clean" vertex="1">
          <mxGeometry height="48" width="245" x="892" y="84" as="geometry" />
        </mxCell>
        <mxCell id="s4bg" parent="1" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#F2FBF4;strokeColor=#81C784;" value="" vertex="1">
          <mxGeometry height="140" width="245" x="892" y="140" as="geometry" />
        </mxCell>
        <mxCell id="s4b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#2E7D32;whiteSpace=wrap;" value="Fallback exercised against a slice of real production shadow traffic. At least one full failover drill completed end-to-end. Contract explicitly covers regulatory suspension, not only standard outage SLA. Stage 4 would have turned the opening scenario into a routing decision rather than an incident." vertex="1">
          <mxGeometry height="126" width="213" x="908" y="146" as="geometry" />
        </mxCell>
        <mxCell id="hbg" parent="1" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#EAF1FB;strokeColor=#CBD8EF;" value="" vertex="1">
